{
  "name": "loup-garou",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"SERVER,CLIENT\" --prefix-colors \"yellow,cyan\" \"pnpm --filter @loup-garou/server dev\" \"pnpm --filter @loup-garou/client dev\"",
    "build": "pnpm --filter @loup-garou/server build && pnpm --filter @loup-garou/client build",
    "db:setup": "pnpm --filter @loup-garou/server db:setup"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
